{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "short_name": "Md2Word",
  "version": "2.0.0",
  "version_name": "2.0.0",
  "description": "__MSG_extDesc__",
  "default_locale": "zh_CN",
  "author": "MarkdownPasteAddin",
  "homepage_url": "https://github.com/user/MarkdownPasteAddin",

  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "storage",
    "sidePanel",
    "downloads",
    "clipboardRead"
  ],

  "host_permissions": [
    "http://localhost:9876/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/browser-polyfill.js", "content/content_script.js"],
      "css": ["content/content_style.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MarkdownPasteAddin",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "popup/sidepanel.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
